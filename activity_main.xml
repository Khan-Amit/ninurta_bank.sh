<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0a0e1a">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📱 NINURTA MINER"
        android:textSize="24sp"
        android:textColor="#ffcc00"
        android:gravity="center"
        android:paddingBottom="8dp"/>

    <!-- Status -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏳ Ready to mine"
        android:textSize="14sp"
        android:textColor="#8da0c0"
        android:gravity="center"
        android:paddingBottom="8dp"/>

    <!-- Earnings -->
    <TextView
        android:id="@+id/earnings_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💰 0.00000000 XMR"
        android:textSize="16sp"
        android:textColor="#88ff88"
        android:gravity="center"
        android:paddingBottom="8dp"/>

    <!-- Stats Display -->
    <TextView
        android:id="@+id/stats_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#010410"
        android:padding="12dp"
        android:textSize="12sp"
        android:textColor="#88ffaa"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp"/>

    <!-- Mining Progress -->
    <ProgressBar
        android:id="@+id/mining_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginBottom="8dp"
        android:progressTint="#33ff66"
        android:indeterminate="false"/>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <Spinner
            android:id="@+id/crypto_spinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#1f2c46"
            android:textColor="#ffffff"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/start_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶ START"
            android:background="#2a5a3a"
            android:textColor="#ffffff"
            android:padding="12dp"/>

        <Button
            android:id="@+id/stop_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏹ STOP"
            android:background="#7a2a2a"
            android:textColor="#ffffff"
            android:padding="12dp"
            android:enabled="false"/>

        <Button
            android:id="@+id/check_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:background="#2a4a7a"
            android:textColor="#ffffff"
            android:padding="12dp"/>
    </LinearLayout>

    <!-- Log Terminal -->
    <ScrollView
        android:id="@+id/log_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#010410"
        android:padding="8dp">

        <TextView
            android:id="@+id/log_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#88ffaa"
            android:fontFamily="monospace"/>
    </ScrollView>

</LinearLayout>
